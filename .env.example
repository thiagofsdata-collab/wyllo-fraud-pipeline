# Copy to .env and fill in real values. Never commit .env.

# -------- AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_RAW_BUCKET=wyllo-fraud-raw-dev
S3_BRONZE_BUCKET=wyllo-fraud-bronze-dev
GLUE_DATABASE=wyllo_fraud_catalog
ATHENA_RESULTS_BUCKET=wyllo-fraud-athena-results

# -------- LLM provider for the RAG layer
# Pick one — the chain auto-detects based on which key is set.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
LLM_MODEL=claude-sonnet-4-5-20250929
LLM_TEMPERATURE=0.0

# -------- DuckDB local warehouse
DUCKDB_PROD_PATH=/var/lib/wyllo/warehouse.duckdb

# -------- Dagster
DAGSTER_HOME=/app/dagster_home

# -------- Streaming simulator
STREAM_BATCH_SECONDS=60
STREAM_ROWS_PER_BATCH=50
